generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Template {
  id     Int     @id @default(autoincrement())
  name   String
  secret String?

  @@map("templates")
}

model User {
  id             Int       @id @default(autoincrement())
  supabaseUserId String    @unique @db.Uuid
  email          String    @unique
  role           Role      @default(STUDENT)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  studentProfile StudentProfile?
  companyProfile CompanyProfile?

  @@map("users")
}

model StudentProfile {
  userId             Int           @id @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  school             String?
  degreeName         String?
  startYear          Int?
  endYear            Int?
  currentLevel       StudyLevel?
  targetLevel        StudyLevel?
  pastDegrees        String[]
  skills             String[]
  fieldOfStudy       FieldOfStudy?
  cvUrl              String?
  isVisible          Boolean       @default(false)
  showLastName       Boolean       @default(false)
  contactPhoneNumber String?
  contactEmail       String?

  @@map("student_profiles")
}

model CompanyProfile {
  userId             Int       @id @unique
  legalName          String
  industry           Industry?
  description        String?   @db.Text
  siret              String?
  isVerified         Boolean   @default(false)
  contactPhoneNumber String?
  contactEmail       String?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers             Offer[]

  @@map("company_profiles")
}

enum OfferStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Offer {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  location     String
  salary       Int?
  status       OfferStatus  @default(DRAFT)
  fieldOfStudy FieldOfStudy // <--- Ajouté selon la règle métier du Rendu 3

  // Relations
  companyId Int
  company   CompanyProfile @relation(fields: [companyId], references: [userId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offers")
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
}

enum Industry {
  AEROSPACE
  AGRICULTURE
  AUTOMOTIVE
  BANKING_INSURANCE
  CONSTRUCTION
  EDUCATION
  ENERGY
  HEALTHCARE
  HOSPITALITY
  IT_SERVICES
  LUXURY
  MANUFACTURING
  MEDIA_ENTERTAINMENT
  RETAIL
  PUBLIC_SECTOR
  TRANSPORT_LOGISTICS
}

enum FieldOfStudy {
  ADMINISTRATION
  ARTS_DESIGN
  BUSINESS_MANAGEMENT
  COMMUNICATION
  COMPUTER_SCIENCE
  DATA_ANALYTICS
  ENGINEERING
  FINANCE_ACCOUNTING
  HUMAN_RESOURCES
  LAW
  MARKETING
  SALES
}

enum StudyLevel {
  BAC_PLUS_2 // BTS, DUT, DEUST
  BAC_PLUS_3 // Licence, Bachelor, BUT
  BAC_PLUS_4 // Master 1
  BAC_PLUS_5 // Master 2, Diplôme d'Ingénieur, École de Commerce
  BAC_PLUS_6 // Master Spécialisé
  DOCTORATE // Doctorat 
}
